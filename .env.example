# Copy this file to .env and fill in the values you have. All settings are
# optional -- without them the engine uses mock clients and is still fully
# functional.

# --- Slack ---
# Create at https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0XXX/B0XXX/XXXXXXXXXXXX

# --- CrowdStrike Falcon ---
# Create an API client in the Falcon console with scopes:
#   Hosts (read+write), Real Time Response (write), Custom IOCs (write)
# FALCON_CLIENT_ID=
# FALCON_CLIENT_SECRET=
# Override the base URL if your Falcon tenant is not in us-1:
#   us-1 (default): https://api.crowdstrike.com
#   us-2:           https://api.us-2.crowdstrike.com
#   eu-1:           https://api.eu-1.crowdstrike.com
#   gov:            https://api.laggar.gcw.crowdstrike.com
# FALCON_BASE_URL=
